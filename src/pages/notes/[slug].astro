---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/content';
import { withBase } from '../../lib/paths';

export async function getStaticPaths() {
  const entries = await getCollection('notes');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | 笔记`} description={entry.data.summary} pageClass="detail-mode">
  <article class="detail-shell">
    <aside class="detail-aside">
      <p class="eyebrow">Note</p>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.summary}</p>
      <dl class="detail-meta">
        <div>
          <dt>日期</dt>
          <dd>{formatDate(entry.data.date.toISOString())}</dd>
        </div>
        <div>
          <dt>分类</dt>
          <dd>{entry.data.category}</dd>
        </div>
        <div>
          <dt>标签</dt>
          <dd>{entry.data.tags.join(' / ')}</dd>
        </div>
      </dl>
      <div class="detail-actions">
        <a class="button-secondary" href={withBase('/notes/')}>返回笔记</a>
        <a class="ghost-button" href={withBase('/explore/')}>进入统一归档</a>
      </div>
    </aside>
    <div class="detail-content prose">
      <Content />
    </div>
  </article>
</BaseLayout>
