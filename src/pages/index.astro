---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SECTION_INFO, formatDate } from '../lib/content';
import { getArchiveEntries, getCollectionEntries, getFeaturedEntries } from '../lib/content-service';
import { withBase } from '../lib/paths';

const [allEntries, featuredEntries, essays] = await Promise.all([
  getArchiveEntries(),
  getFeaturedEntries(),
  getCollectionEntries('essays'),
]);

const counts = {
  total: allEntries.length,
  bookmarks: allEntries.filter((entry) => entry.collection === 'bookmarks').length,
  notes: allEntries.filter((entry) => entry.collection === 'notes').length,
  quotes: allEntries.filter((entry) => entry.collection === 'quotes').length,
  essays: allEntries.filter((entry) => entry.collection === 'essays').length,
};

const chambers = Object.entries(SECTION_INFO);
const chamberCounts = { bookmarks: counts.bookmarks, notes: counts.notes, quotes: counts.quotes, essays: counts.essays } as const;

const pickUnique = (entries: typeof allEntries) => {
  const seen = new Set<string>();
  return entries.filter((entry) => {
    if (seen.has(entry.id)) return false;
    seen.add(entry.id);
    return true;
  });
};

const heroEntry = essays[0] ?? featuredEntries[0] ?? allEntries[0];
const storyEntries = pickUnique([
  ...essays.slice(1),
  ...featuredEntries,
  ...allEntries.filter((entry) => entry.collection === 'essays'),
  ...allEntries.filter((entry) => entry.collection === 'notes'),
  ...allEntries,
]).filter((entry) => entry.id !== heroEntry?.id);

const feedEntries = storyEntries.slice(0, 6);
---

<BaseLayout
  title="Henry 的数字花园"
  description="一个带着蓝白天空梦境气质的个人博客首页，把长文、笔记和收藏放进更轻盈的背景里。"
  pageClass="home-mode"
>
  <section class="dream-hero" style={`--dream-hero-bg: url('${withBase('/backgrounds/dream-sky.svg')}')`}>
    <div class="dream-hero-inner">
      <p class="dream-overline">Personal Blog</p>
      <h1>Henry 的数字花园</h1>
      <p class="dream-lead">把长文、笔记、摘录和收藏，放进一片更轻、更安静的天空里。</p>

      <a class="dream-search" href={withBase('/explore/')}>
        <span class="search-icon">⌕</span>
        <span>搜索文章标题、标签或分类内容...</span>
      </a>

      <div class="dream-room-pills">
        {chambers.map(([key, value]) => (
          <a class="dream-room-pill" href={withBase(value.href)}>
            <span>{key === 'essays' ? '长文' : value.label}</span>
            <small>{chamberCounts[key as keyof typeof chamberCounts]} 篇</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  {heroEntry && (
    <section class="dream-feature-wrap">
      <div class="dream-section-head">
        <p class="eyebrow">Featured Story</p>
        <h2>先读这一篇</h2>
      </div>

      <article class:list={['dream-feature-card', `is-${heroEntry.collection}`]}>
        <div class="dream-feature-art">
          <span class="entry-pill">{heroEntry.section}</span>
          <div class="dream-feature-glow"></div>
          <div class="dream-feature-caption">
            <span class="dream-cover-kicker">Latest Story</span>
            <strong>{heroEntry.title}</strong>
            <small>{heroEntry.category}</small>
          </div>
        </div>
        <div class="dream-feature-body">
          <time datetime={heroEntry.date}>{formatDate(heroEntry.date)}</time>
          <h3>
            <a href={withBase(heroEntry.permalink)}>{heroEntry.title}</a>
          </h3>
          <p>{heroEntry.summary}</p>
          <div class="dream-feature-actions">
            <a class="button-primary" href={withBase(heroEntry.permalink)}>阅读文章</a>
            <a class="button-secondary" href={withBase('/garden/')}>查看全部长文</a>
          </div>
        </div>
      </article>
    </section>
  )}

  <section class="dream-feed-wrap">
    <div class="dream-section-head">
      <p class="eyebrow">Recent Writing</p>
      <h2>最近文章</h2>
      <p>首页以文章阅读为主，其他内容则作为轻入口保留在这片天空下面。</p>
    </div>

    <div class="dream-feed-grid">
      {feedEntries.map((entry, index) => (
        <article class:list={['dream-post-card', `is-${entry.collection}`, index === 0 && 'is-wide']}>
          <div class="dream-post-cover">
            <span class="entry-pill">{entry.section}</span>
            <div class="dream-post-cover-inner">
              <span class="dream-cover-kicker">{entry.category}</span>
              <strong>{entry.title}</strong>
            </div>
          </div>
          <div class="dream-post-body">
            <time datetime={entry.date}>{formatDate(entry.date)}</time>
            <h3>
              <a href={withBase(entry.permalink)}>{entry.title}</a>
            </h3>
            <p>{entry.summary}</p>
            <div class="dream-post-meta">
              <span>{entry.category}</span>
              <a href={withBase(entry.permalink)}>继续阅读</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="dream-side-rooms">
    <div class="dream-section-head">
      <p class="eyebrow">Other Rooms</p>
      <h2>其他房间</h2>
    </div>

    <div class="dream-room-grid">
      {chambers.map(([key, value]) => (
        <a class:list={['dream-room-card', `is-${key}`]} href={withBase(value.href)}>
          <strong>{key === 'essays' ? '花园随想' : value.label}</strong>
          <p>{value.description}</p>
          <span>{chamberCounts[key as keyof typeof chamberCounts]} 条内容</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
