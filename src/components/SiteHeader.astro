---
import { withBase, withoutBase } from '../lib/paths';

const navItems = [
  { href: '/', label: '首页' },
  { href: '/explore/', label: '归档' },
  { href: '/bookmarks/', label: '网站收藏' },
  { href: '/notes/', label: '笔记' },
  { href: '/quotes/', label: '摘录' },
  { href: '/garden/', label: '花园' },
];

const currentPath = withoutBase(Astro.url.pathname);
---

<header class="site-header">
  <a class="brand" href={withBase('/')}>
    <span class="brand-mark">H</span>
    <span>
      <strong>Henry 的数字花园</strong>
      <small>收藏、笔记与慢慢长出来的文字</small>
    </span>
  </a>

  <p class="brand-note">一个持续维护的私人归档站，用来收纳网页、笔记、摘录和长文入口。</p>

  <nav class="site-nav" aria-label="主导航">
    {navItems.map((item) => (
      <a class:list={['nav-link', currentPath === item.href && 'is-active']} href={withBase(item.href)}>
        {item.label}
      </a>
    ))}
  </nav>

  <div class="header-meta" aria-label="站点特性">
    <span>长期维护</span>
    <span>Markdown 驱动</span>
    <span>GitHub Pages</span>
  </div>
</header>
